{
  "name": "driver-pulse-server",
  "version": "1.0.0",
  "description": "Driver Pulse Motion Detection Server",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db-verify": "ts-node src/verifyDb.ts",
    "db-setup": "ts-node src/db/setupSchema.ts && ts-node src/db/seedDriverGoals.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "csv-parser": "^3.2.0",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "mysql2": "^3.19.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.8",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
